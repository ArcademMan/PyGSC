			"example": "hud = createtexthud('Hello World', 2, 'center', 'middle')",
			"mandatory1": "<text> The text to display.",
			"optional1": "[fontscale] font size, default 1.",
			"optional2": "[alignX] horizontal align.",
			"optional3": "[alignY] vertical align.",
			"optional4": "[horzAlign] horizontal alignment mode.",
			"optional5": "[vertAlign] vertical alignment mode.",
			"optional6": "[global] if true, visible to all players.",
			"optional7": "[color] RGB color tuple."
		},
		"createshaderhud": {
			"translation": "j_utility::createShaderHuD",
			"fullAPI": "createshaderhud(<shader>, [alignY], [alignX], [height], [width])",
			"summary": "Create an image/shader HUD element.",
			"example": "hud = createshaderhud('white', 'middle', 'center', 50, 200)",
			"mandatory1": "<shader> The shader/image name.",
			"optional1": "[alignY] vertical align.",
			"optional2": "[alignX] horizontal align.",
			"optional3": "[height] height in pixels.",
			"optional4": "[width] width in pixels."
		},
		"destroyhud": {
			"translation": "j_utility::destroyTextHuD",
			"fullAPI": "destroyhud(<element>, [timer])",
			"summary": "Fade out and destroy a HUD element.",
			"example": "destroyhud(hud, 1.5)",
			"mandatory1": "<element> The HUD element to destroy.",
			"optional1": "[timer] fade out duration in seconds."
		},
		"setwaypoint": {
			"translation": "objPoints::create",
			"fullAPI": "setwaypoint(<name>, <origin>, <team>, <icon>)",
			"summary": "Create a waypoint/objective marker on screen.",
			"example": "wp = setwaypoint('obj_marker', struct.origin + (0,0,85), 'all', 'waypoint_icon')",
			"mandatory1": "<name> Unique name for the waypoint.",
			"mandatory2": "<origin> The world position.",
			"mandatory3": "<team> 'all', 'allies', or 'axis'.",
			"mandatory4": "<icon> The icon shader to display."
		},
		"luinotify": {
			"translation": "LUINotifyEvent",
			"fullAPI": "luinotify(<event>, <param_count>, ...params)",
			"summary": "Send a LUI notification event to the client UI.",
			"example": "player luinotify(&'workbench', 3, 1, idx, level.unlocked)",
			"mandatory1": "<event> The event name reference.",
			"mandatory2": "<param_count> Number of parameters following.",
			"mandatory3": "...params The parameter values."
		}
	},
	"vectors": {
		"randorigin": {
			"translation": "j_utility::getRandomOriginFromPoint",
			"fullAPI": "randorigin(<point>, [z_offset], [mindist], [maxdist], [search_radius], [out_of_boundries])",
			"summary": "Get a random navmesh position from a point.",
			"example": "pos = randorigin(self.origin, 0, 50, 300)",
			"mandatory1": "<point> The center origin.",
			"optional1": "[z_offset] height offset.",
			"optional2": "[mindist] minimum distance from point.",
			"optional3": "[maxdist] maximum distance from point.",
			"optional4": "[search_radius] navmesh search radius.",
			"optional5": "[out_of_boundries] allow out of bounds results."
		},
		"pointfromangle": {
			"translation": "j_utility::getPointFromDistanceAndAngles",
			"fullAPI": "pointfromangle(<origin>, <angle>, <distance>, [use_z])",
			"summary": "Calculate a point given an origin, angle and distance.",
			"example": "pos = pointfromangle(self.origin, self.angles, 200)",
			"mandatory1": "<origin> The starting origin.",
			"mandatory2": "<angle> The direction angle.",
			"mandatory3": "<distance> The distance from origin.",
			"optional1": "[use_z] if true, use Z axis too."
		},
		"traceeye": {
			"translation": "j_utility::getTraceFromEye",
			"fullAPI": "traceeye([scale], [hitchar], [offset])",
			"summary": "Raycast from player's eye/view direction. Called on player.",
			"example": "hit = self traceeye(1, true)",
			"optional1": "[scale] trace distance scale.",
			"optional2": "[hitchar] if true, trace hits characters.",
			"optional3": "[offset] eye position offset."
		},
		"canseeme": {
			"translation": "j_utility::canPlayerSeeMe",
			"fullAPI": "canseeme(<player>)",
			"summary": "Check if a player can see this entity.",
			"example": "if model canseeme(player)",
			"mandatory1": "<player> The player to check line of sight from."
		},
		"navmeshpoint": {
			"translation": "GetClosestPointOnNavMesh",
			"fullAPI": "navmeshpoint(<origin>, [radius], [boundary])",
			"summary": "Get the closest valid point on the navmesh.",
			"example": "point = navmeshpoint(self.origin, 250, 15)",
			"mandatory1": "<origin> The origin to search from.",
			"optional1": "[radius] Search radius.",
			"optional2": "[boundary] Boundary distance."
		}
	},
	"attackable": {
		"makeattackable": {
			"translation": "j_attackable::makeAttackable",
			"fullAPI": "makeattackable(<name>, <hp>, [team], [priority], [attack_spots])",
			"summary": "Make a model attackable by zombies with HP and attack slots.",
			"example": "model thr makeattackable('tower_1', 5000, 'noteam', 3, 10)",
			"mandatory1": "<name> Unique name for the attackable.",
			"mandatory2": "<hp> Hit points of the object.",
			"optional1": "[team] Team name, default 'noteam'.",
			"optional2": "[priority] 0-5, higher = less priority for zombies.",
			"optional3": "[attack_spots] Number of zombie attack positions around the object."
		},
		"searchattackable": {
			"translation": "j_attackable::searchAttackable",
			"fullAPI": "searchattackable(<team>, [attackable])",
			"summary": "Flag zombies to start attacking attackable objects.",
			"example": "zombies thr searchattackable('noteam')",
			"mandatory1": "<team> The team of attackables to target.",
			"optional1": "[attackable] specific attackable to target."
		}
	}
}