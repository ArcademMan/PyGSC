 {
	"language-constructs": {
		"def": {
			"translation": "function",
			"fullAPI": "def <function name>(params):",
			"summary": "Python form of 'Function', shorter.",
			"example": "def myfunction(param1, param2):",
			"mandatory1": "<function name> name of the function"
        },
		"autoexec": {
			"translation": "function autoexec",
			"fullAPI": "autoexec <function name>(params):",
			"summary": "Python form of 'Function autoexec', shorter.",
			"example": "autoexec myfunction():",
			"mandatory1": "<function name> name of the function"
        },
		"pass": {
			"translation": "//this is a placeholder pass",
			"fullAPI": "pass",
			"summary": "Python pass to add placeholders.",
			"example": "if something\n\tpass"
        },
		"import": {
			"translation": "#using",
			"fullAPI": "import <path>",
			"summary": "Python-style import, translates to #using in GSC.",
			"example": "import scripts\\zm\\_zm_score"
        },
		"include": {
			"translation": "#insert",
			"fullAPI": "include <path>",
			"summary": "Python-style include, translates to #insert in GSC.",
			"example": "include scripts\\shared\\shared.gsh"
        },
		"fname": {
			"translation": "#namespace",
			"fullAPI": "fname <name>",
			"summary": "Defines the script namespace, translates to #namespace in GSC.",
			"example": "fname points"
        },
		"#": {
			"translation": "//",
			"fullAPI": "#",
			"summary": "Python comment",
			"example": "#comment"
        },
		"animtree": {
			"translation": "#animtree",
			"fullAPI": "animtree",
			"summary": "GSC #animtree directive. Use 'animtree' instead of '#animtree' to avoid comment issues.",
			"example": "model UseAnimTree(animtree)"
        },
		"$define": {
			"translation": "#define",
			"fullAPI": "$define <name> <value>",
			"summary": "Preprocessor #define. Use '$define' in PyGSC instead of '#define'.",
			"example": "$define SPAWNERS_TO_REMOVE array(\"xur_spawner\")"
        },
		"animgeneric": {
			"translation": "",
			"fullAPI": "animgeneric",
			"summary": "Shortcut for #using_animtree( \"generic\" ) directive.",
			"example": "animgeneric"
        }
    },
	"logics-operator": {
		"or": {
			"translation": "||",
			"fullAPI": "or ",
			"summary": "Python OR operator, || in GSC.",
			"example": "if variable or variable2"
        },
		"and": {
			"translation": "&&",
			"fullAPI": "and ",
			"summary": "Python AND operator, && in GSC.",
			"example": "if variable and variable2"
        },
		"greater": {
			"translation": ">",
			"fullAPI": "greater ",
			"summary": "My custom > operator, > in GSC.",
			"example": "if variable greater variable2"
        },
		"minor": {
			"translation": "<",
			"fullAPI": "minor",
			"summary": "My custom < operator, < in GSC.",
			"example": "if variable minor variable2"
        },
		"inequal": {
			"translation": "!=",
			"fullAPI": "inequal ",
			"summary": "My custom != operator, != in GSC.",
			"example": "if variable inequal variable2"
        },
		"not": {
			"translation": "!",
			"fullAPI": "not",
			"summary": "Python not operator, ! in GSC.",
			"example": "if not variable"
        },
		"none": {
			"translation": "undefined",
			"fullAPI": "none",
			"summary": "Python None operator, undefined in GSC.",
			"example": "variable = none"
        },
		"null": {
			"translation": "undefined",
			"fullAPI": "none",
			"summary": "java Null operator, undefined in GSC.",
			"example": "variable = null"
        }
    },
	"gsc-shortcuts": {
		"thr": {
			"translation": "thread",
			"fullAPI": "thread",
			"summary": "shorter version of thread. i know is not that long but i hate it.",
			"example": "thr functionname()"
        },
		"end": {
			"translation": "endon",
			"fullAPI": "end(<string>)",
			"summary": "shorter version of endon.",
			"example": "self end('death')"
        },
		"wait_blackscreen": {
			"translation": "level flag::wait_till( \"initial_blackscreen_passed\" )",
			"fullAPI": "wait_blackscreen",
			"summary": "wait till the black screen is passed.",
			"example": "wait_blackscreen"
        },
		"wait_any": {
			"translation": "util::waittill_any_return",
			"fullAPI": "wait_any('str1', 'death', 'reload', 'whatever')",
			"summary": "Wait any string and return it.",
			"example": "msg = wait_any('str1', 'death', 'reload', 'whatever')"
        },
		"adjazone": {
			"translation": "zm_zonemgr::add_adjacent_zone",
			"fullAPI": "adjazone(<zone1>, <zone2>, <flag>)",
			"summary": "Connect two zones, unlocked when the flag is set.",
			"example": "adjazone('start_zone', 'z0_zone', 'enter_z0')",
			"mandatory1": "<zone1> The first zone name.",
			"mandatory2": "<zone2> The adjacent zone name.",
			"mandatory3": "<flag> The flag that opens the connection."
		},
		"regclientfield": {
			"translation": "clientfield::register",
			"fullAPI": "regclientfield(<entity_type>, <field_name>, <version>, <bits>, <type>)",
			"summary": "Register a clientfield for network sync.",
			"example": "regclientfield('actor', 'dog_fx', VERSION_SHIP, 1, 'int')",
			"mandatory1": "<entity_type> Type: 'actor', 'scriptmover', 'toplayer', etc.",
			"mandatory2": "<field_name> The field name string.",
			"mandatory3": "<version> Version constant, usually VERSION_SHIP.",
			"mandatory4": "<bits> Number of bits for the field.",
			"mandatory5": "<type> Field type: 'int', 'counter', 'float'."
		},
		"getdvar": {
			"translation": "GetDvarString",
			"fullAPI": "getdvar(<name>)",
			"summary": "Get a dvar value as string.",
			"example": "val = getdvar('zombie_dog_animset')",
			"mandatory1": "<name> The dvar name."
		},
		"setdvar": {
			"translation": "SetDvar",
			"fullAPI": "setdvar(<name>, <value>)",
			"summary": "Set a dvar value.",
			"example": "setdvar('ai_meleeRange', 100)",
			"mandatory1": "<name> The dvar name.",
			"mandatory2": "<value> The value to set."
		}
    },
	"my-common-misspell": {
		"waitill": {
			"translation": "waittill",
			"fullAPI": "<entity> waittill(<string>) ",
			"summary": "my common mistake for 'waittill'",
			"example": "struct waitill('something')",
			"mandatory1": "<entity> something that is waiting for an event to happen, can be level too.",
			"mandatory2": "<string> string needed to wait a specific string event."
        }
    },
	"player-related": {
		"givepoints": {
			"translation": "zm_score::add_to_player_score",
			"fullAPI": "givepoints(<points>)",
			"summary": "Custom command to give a player points.",
			"example": "player givepoints(500)",
			"mandatory1": "<player> the player to give point to.",
			"mandatory2": "<points> int of the points to give to a player."
        },
        "takepoints": {
            "translation": "zm_score::minus_to_player_score",
            "fullAPI": "takepoints(<points>)",
            "summary": "Custom command to give a player points.",
            "example": "player takepoints(500)",
            "mandatory1": "<player> the player to take point to.",
            "mandatory2": "<points> int of the points to take to a player."
        },
		"$players": {
			"translation": "GetPlayers()",
			"fullAPI": "$players",
			"summary": "Return the array of the players.",
			"example": "foreach player in $players"
		},
		"giveweapon": {
			"translation": "zm_weapons::weapon_give",
			"fullAPI": "giveweapon(<weapon>, [is_upgrade = false], [magic_box = false], [nosound = false], [b_switch_weapon = true])",
			"summary": "Give the weapon to a player.",
			"example": "player giveweapon('ray_gun')",
			"mandatory1": "<weapon> the weapon to give.",
			"optional1": "[is_upgrade] default false, give the upgraded weapon of the weapon",
			"optional2": "[magic_box] default false, i don't know what that do.",
			"optional3": "[nosound] default false, if true the '$$$$ sound' will not play.",
			"optional4": "[b_switch_weapon] default true, switch to the given weapon."
		},
		"jteleporthere": {
			"translation": "thread j_utility::teleportHere",
			"fullAPI": "teleporthere(<vec or model or struct>)",
			"summary": "Teleport the player to the given location",
			"example": "player teleporthere(model)",
			"mandatory1": "<vec or model or struct> the weapon to give."
		},
		"burn": {
			"translation": "burnplayer::SetPlayerBurning",
			"fullAPI": "burn(<duration>, <interval>, <damage per interval>)",
			"summary": "Set the player on fire, on its view and on third person.",
			"example": "player burn(10, 2, 4)",
			"mandatory1": "<duration> The duration of the fire.",
			"mandatory2": "<interval> Time in seconds on how often you take fire damage.",
			"mandatory3": "<damage per interval> Damage inflict every interval."
		},
		"forcekillplayer": {
			"translation": "j_utility::forceKillPlayer",
			"fullAPI": "forcekillplayer()",
			"summary": "Kill the player even if in god mode.",
			"example": "player forcekillplayer"
		},
		"inflictdamage": {
			"translation": "j_utility::inflictDamage",
			"fullAPI": "inflictdamage(<victim>, <damage>)",
			"summary": "Deal damage to a victim, accounting for armor.",
			"example": "self inflictdamage(player, 50)",
			"mandatory1": "<victim> The entity to damage.",
			"mandatory2": "<damage> Amount of damage to deal."
		},
		"isplayervalid": {
			"translation": "zm_utility::is_player_valid",
			"fullAPI": "isplayervalid(<player>)",
			"summary": "Check if a player is valid (alive, not in laststand, not spectating).",
			"example": "if isplayervalid(player)",
			"mandatory1": "<player> The player to validate."
		},
		"isinlaststand": {
			"translation": "laststand::player_is_in_laststand",
			"fullAPI": "isinlaststand()",
			"summary": "Check if a player is in last stand.",
			"example": "if player isinlaststand"
		},
		"switchweapon": {
			"translation": "SwitchToWeaponImmediate",
			"fullAPI": "switchweapon(<weapon>)",
			"summary": "Immediately switch the player to a weapon.",
			"example": "player switchweapon(GetWeapon('smg_mp40'))",
			"mandatory1": "<weapon> The weapon to switch to."
		},
		"takeweapon": {
			"translation": "TakeWeapon",
			"fullAPI": "takeweapon(<weapon>)",
			"summary": "Take a weapon from a player.",
			"example": "player takeweapon(GetWeapon('smg_mp40'))",
			"mandatory1": "<weapon> The weapon to remove."
		},
		"getweapon": {
			"translation": "GetWeapon",
			"fullAPI": "getweapon(<name>)",
			"summary": "Get a weapon object from its string name.",
			"example": "w = getweapon('smg_mp40')",
			"mandatory1": "<name> The weapon name string."
		}
    },
	"zombie-related": {
		"spawnzombie": {
			"translation": "j_utility::spawnZombie",
			"fullAPI": "spawnZombie([actor], <positions>, [model])",
			"summary": "Custom commands from j utils to spawn a zombie.",
			"example": "zom = spawnZombie(none, structs)",
			"optional1": "<actor> You can set a specific actor to spawn, otherwise stardards zombies.",
			"mandatory1": "<positions> Spawn point or spawn points where you want the zombie to spawn.",
			"optional2": "[model] set a specific model to the spawned zombie."
        },
		"setzombiespeed": {
			"translation": "zombie_utility::set_zombie_run_cycle_override_value",
			"fullAPI": "setzombiespeed(<run state>)",
			"summary": "Make the zombie, walk, run, sprint or supersprinter",
			"example": "zom setzombiespeed('run')",
			"mandatory1": "<run state> String for the zombie state, walk, run, sprint or supersprinter"
		}
	},
	"structs": {
		"getstructs": {
			"translation": "struct::get_array",
			"fullAPI": "getstructs(<targetname>)",
			"summary": "Shorter version to get structs.",
			"mandatory1": "<targetname> targetname on radiant."
        },
		"getstruct": {
			"translation": "struct::get",
			"fullAPI": "getstruct(<targetname>)",
			"summary": "Shorter version to get a single struct.",
			"mandatory1": "<targetname> targetname on radiant."
        }
    },
	"loads": {
		"precache": {
			"translation": "#precache",
			"fullAPI": "precache(<type>, <name>)",
			"summary": "Use to precache xmodel, fx, xanim etc...",
			"example": "precache 'fx', 'smoke"
		},
		"using_animtree": {
			"translation": "#using_animtree( 'generic')",
			"fullAPI": "using animtree",
			"summary": "load the generic animtree."
		},
		"$define": {
            "translation": "#define",
            "fullAPI": "$define",
            "summary": "create a define",
			"example": "$define SOMETHING 12345"
        }
	},
	"arrays": {
		"randomize": {
			"translation": "array::randomize",
			"fullAPI": "randomize(<array>)",
			"summary": "Return a randomized array.",
			"example": "array = randomize oldarray"
		},
		"arrayinsert": {
			"translation": "ArrayInsert",
			"fullAPI": "arrayinsert(<array>, <item>, <index>)",
			"summary": "Insert an item into an array at a given index.",
			"example": "arrayinsert(weapons, gun, weapons.size)",
			"mandatory1": "<array> The array to insert into.",
			"mandatory2": "<item> The item to insert.",
			"mandatory3": "<index> The position to insert at."
		},
		"isinarray": {
			"translation": "IsInArray",
			"fullAPI": "isinarray(<array>, <item>)",
			"summary": "Check if an item is in an array.",
			"example": "if isinarray(weapons, gun)",
			"mandatory1": "<array> The array to search.",
			"mandatory2": "<item> The item to look for."
		}
	},
	"triggers": {
		"maketrigger": {
			"translation": "j_utility::makeTriggerRadiusUse",
			"fullAPI": "maketrigger(<origin>, <text>, [position offset])",
			"summary": "Return a created trigger radius use on a given spot.",
			"example": "trigger = maketriggerradiususe(player.origin, 'Press ^3&&1^7 to kill everybody')",
			"mandatory1": "<origin> The place given as entity or vector",
			"mandatory2": "<text> text hint of the trigger.",
			"optional1": "Position offset to spawn."
        },
		"sethintstring": {
			"translation": "SetHintString",
			"fullAPI": "sethintstring(<text>)",
			"summary": "Set the hint text on a trigger.",
			"example": "trigger sethintstring('Press $use to open')",
			"mandatory1": "<text> The hint text to display."
		},
		"setcursorhint": {
			"translation": "SetCursorHint",
			"fullAPI": "setcursorhint(<type>)",
			"summary": "Set the cursor hint icon type on a trigger.",
			"example": "trigger setcursorhint('HINT_NOICON')",
			"mandatory1": "<type> Hint type: 'HINT_NOICON', 'HINT_ACTIVATE', etc."
		},
		"setteamtrigger": {
			"translation": "SetTeamForTrigger",
			"fullAPI": "setteamtrigger(<team>)",
			"summary": "Set which team can activate a trigger.",
			"example": "trigger setteamtrigger('allies')",
			"mandatory1": "<team> The team name: 'allies', 'axis', etc."
		}
    },
    "models": {
		"spawnmodel": {
			"translation": "util::spawn_model",
			"fullAPI": "spawnmodel(<modelname>, <position>, [angles])",
			"summary": "Return a spawned model on the given spot.",
			"example": "struct.model = util::spawn_model('p7_tools_screwdriver', struct.origin, struct.angles);",
			"mandatory1": "<modelname> the model name on APE.",
			"mandatory2": "<position> The place given as vector",
			"optional1": "[angles] Angles of the model as vector."
        },
		"jspinme": {
			"translation": "j_utility::spinMe",
			"fullAPI": "jspinme()",
			"summary": "make something spin on Y axis",
			"example": "model spinme"
        },
		"jfloatme": {
			"translation": "j_utility::floatMe",
			"fullAPI": "floatme()",
			"summary": "make something float on Z axis",
			"example": "model floatme"
        },
		"jdeleteme": {
			"translation": "j_utility::deleteMe",
			"fullAPI": "jdeleteme([time])",
			"summary": "Delete an entity after an optional delay.",
			"example": "model thr jdeleteme(5)",
			"optional1": "[time] delay in seconds before deleting."
		},
		"jrandomspin": {
			"translation": "j_utility::randomSpinMe",
			"fullAPI": "jrandomspin()",
			"summary": "Apply a random spin rotation pattern to an entity.",
			"example": "model thr jrandomspin"
		},
		"enablelinkto": {
			"translation": "EnableLinkTo",
			"fullAPI": "enablelinkto()",
			"summary": "Enable an entity to be linked to another entity.",
			"example": "model enablelinkto"
		},
		"linkto": {
			"translation": "LinkTo",
			"fullAPI": "linkto(<entity>, [tag], [offset], [angles_offset])",
			"summary": "Link this entity to another entity.",
			"example": "model linkto(vehicle, 'tag_origin')",
			"mandatory1": "<entity> The entity to link to.",
			"optional1": "[tag] The bone/tag to link to.",
			"optional2": "[offset] Position offset vector.",
			"optional3": "[angles_offset] Angles offset vector."
		},
		"getweaponmodel": {
			"translation": "GetWeaponWorldModel",
			"fullAPI": "getweaponmodel(<weapon>)",
			"summary": "Get the world model name of a weapon.",
			"example": "model_name = getweaponmodel(getweapon('smg_mp40'))",
			"mandatory1": "<weapon> The weapon object."
		}
    },
	"output": {
		"print": {
			"translation": "iprintlnbold",
			"fullAPI": "iprintlnbold(<text>)",
			"summary": "Print a string on screen.",
			"mandatory1": "<text> The text you want to see on the screen."
        },
		"$use": {
			"translation": "^3&&1^7",
			"fullAPI": "$use",
			"summary": "Convert use with ^3&&1^7 (color yellow of your use button)"
        }
    },
	"FX": {
		"jplayfx": {
			"translation": "j_utility::playFxModel",
			"fullAPI": "playfxon(<model or struct>, <fx>, [duration])",
			"summary": "Return a spawned invisible model with an fx applied to it, with the given duration. Last forever if no duration is provided, or until the returned model has been deleted.",
			"mandatory1": "<model or struct> An existing model, or struct, or a vector.",
			"mandatory2": "<fx> string of an FX, must be precached first.",
			"optional1": "[duration] duration in seconds, if omitted, will last forever or till deleted."
        },
		"playfxontag": {
			"translation": "PlayFXOnTag",
			"fullAPI": "playfxontag(<fx>, <entity>, <tag>)",
			"summary": "Play an FX on a specific tag/bone of an entity.",
			"example": "playfxontag(level._effect['fire'], model, 'tag_origin')",
			"mandatory1": "<fx> The FX to play.",
			"mandatory2": "<entity> The entity to play the FX on.",
			"mandatory3": "<tag> The bone/tag name."
		}
    },
	"callbacks": {
		"zombie_death_cb": {
			"translation": "zm_spawner::register_zombie_death_event_callback",
			"fullAPI": "zombie_death_cb(<&function>)",
			"summary": "Call the &function when a zombie die, giving the zombie as self.",
			"example": "zombie_death_cb(&zombie_death)",
			"mandatory1": "<&function> The function to delegate."
        },
		"actor_damage_cb": {
			"translation": "zm::register_actor_damage_callback",
			"fullAPI": "actor_damage_cb(<&function>)",
			"summary": "Call the &function when an actor take damage, giving the AI as self.",
			"example": "actor_damage_cb(&zombie_damage)",
			"mandatory1": "<&function> The function to delegate."
        },
		"on_spawned_cb": {
			"translation": "callback::on_spawned",
			"fullAPI": "on_spawned_cb(<&function>)",
			"summary": "Call the &function when a player spawn from spectator.",
			"example": "on_spawned_cb(&zombie_death)",
			"mandatory1": "<&function> The function to delegate."
        },
		"player_damage_cb": {
			"translation": "zm::register_player_damage_callback",
			"fullAPI": "player_damage_cb(<&function>)",
			"summary": "Call the &function when a player take damage.",
			"example": "player_damage_cb(&zombie_death)",
			"mandatory1": "<&function> The function to delegate."
        },
		"on_connect_cb": {
			"translation": "callback::on_connect",
			"fullAPI": "on_connect_cb(<&function>)",
			"summary": "Call the &function when a player connect into the game.",
			"example": "on_connect_cb(&zombie_death)",
			"mandatory1": "<&function> The function to delegate."
        }
	},
	"powerups": {
		"removepowerups": {
			"translation": "zm_spawner::register_zombie_death_event_callback",
			"fullAPI": "removepowerups(<powerup>)",
			"summary": "Remove a powerup from the map, don't remove them all or the map will crash.",
			"example": "removepowerups('nuke')",
			"mandatory1": "<powerup> The string of the powerup name: minigun, nuke, insta_kill, full_ammo"
        }
	},
	"flags": {
		"flaginit": {
			"translation": "level flag::init",
			"fullAPI": "flaginit(<flag_name>)",
			"summary": "Initialize a flag on level. Auto-prepends 'level'.",
			"example": "flaginit('power_on')",
			"mandatory1": "<flag_name> The string name of the flag to initialize."
		},
		"flagset": {
			"translation": "level flag::set",
			"fullAPI": "flagset(<flag_name>)",
			"summary": "Set a flag on level. Auto-prepends 'level'.",
			"example": "flagset('power_on')",
			"mandatory1": "<flag_name> The string name of the flag to set."
		},
		"flagwait": {
			"translation": "level flag::wait_till",
			"fullAPI": "flagwait(<flag_name>)",
			"summary": "Wait until a flag is set on level. Auto-prepends 'level'.",
			"example": "flagwait('power_on')",
			"mandatory1": "<flag_name> The string name of the flag to wait for."
		},
		"flagclear": {
			"translation": "level flag::wait_till_clear",
			"fullAPI": "flagclear(<flag_name>)",
			"summary": "Wait until a flag is cleared on level. Auto-prepends 'level'.",
			"example": "flagclear('power_on')",
			"mandatory1": "<flag_name> The string name of the flag to wait for clear."
		}
	},
	"entities": {
		"getent": {
			"translation": "GetEnt",
			"fullAPI": "getent(<name>, <key>)",
			"summary": "Get a single entity by key/value pair.",
			"example": "door = getent('door1', 'targetname')",
			"mandatory1": "<name> The value to search for.",
			"mandatory2": "<key> The key to search on (e.g. 'targetname')."
		},
		"getents": {
			"translation": "GetEntArray",
			"fullAPI": "getents(<name>, <key>)",
			"summary": "Get an array of entities by key/value pair.",
			"example": "doors = getents('doors', 'targetname')",
			"mandatory1": "<name> The value to search for.",
			"mandatory2": "<key> The key to search on (e.g. 'targetname')."
		}
	},
	"sound": {
		"playsound": {
			"translation": "PlaySoundAtPosition",
			"fullAPI": "playsound(<sound>, <position>)",
			"summary": "Play a sound at a position.",
			"example": "playsound('mus_gameover', self.origin)",
			"mandatory1": "<sound> The sound alias to play.",
			"mandatory2": "<position> The position (vector) to play the sound at."
		},
		"loopsound": {
			"translation": "PlayLoopSound",
			"fullAPI": "loopsound(<sound>)",
			"summary": "Play a looping sound on an entity.",
			"example": "model loopsound('amb_fire_loop')",
			"mandatory1": "<sound> The sound alias to loop."
		},
		"stopsound": {
			"translation": "StopLoopSound",
			"fullAPI": "stopsound(<sound>)",
			"summary": "Stop a looping sound on an entity.",
			"example": "model stopsound('amb_fire_loop')",
			"mandatory1": "<sound> The sound alias to stop."
		},
		"jplaysoundon": {
			"translation": "j_utility::playSoundOn",
			"fullAPI": "jplaysoundon(<alias>, [tag], [ends_on_death])",
			"summary": "Play a sound on an entity at a specific tag/bone.",
			"example": "model jplaysoundon('fire_loop', 'tag_origin', true)",
			"mandatory1": "<alias> The sound alias to play.",
			"optional1": "[tag] The bone/tag to play the sound on.",
			"optional2": "[ends_on_death] if true, stop sound when entity dies."
		}
	},
	"math": {
		"randint": {
			"translation": "RandomInt",
			"fullAPI": "randint(<max>)",
			"summary": "Returns a random integer from 0 to max-1.",
			"example": "n = randint(100)",
			"mandatory1": "<max> The exclusive upper bound."
		},
		"randfloat": {
			"translation": "RandomFloatRange",
			"fullAPI": "randfloat(<min>, <max>)",
			"summary": "Returns a random float between min and max.",
			"example": "f = randfloat(0.5, 2.0)",
			"mandatory1": "<min> The minimum value.",
			"mandatory2": "<max> The maximum value."
		}
	},
	"zombie-control": {
		"disablezombiespawn": {
			"translation": "j_utility::disableZombieSpawn",
			"fullAPI": "disablezombiespawn",
			"summary": "Disable round zombie spawners.",
			"example": "disablezombiespawn"
		},
		"enablezombiespawn": {
			"translation": "j_utility::enableZombieSpawn",
			"fullAPI": "enablezombiespawn",
			"summary": "Re-enable round zombie spawners.",
			"example": "enablezombiespawn"
		},
		"forcekillzombie": {
			"translation": "j_utility::forceKillZombie",
			"fullAPI": "forcekillzombie([delete])",
			"summary": "Kill all zombies on the map.",
			"example": "forcekillzombie(true)",
			"optional1": "[delete] if true, also delete the corpses."
		},
		"respawnzombie": {
			"translation": "j_utility::respawnZombie",
			"fullAPI": "respawnzombie()",
			"summary": "Add the zombie back to the respawn queue.",
			"example": "zom respawnzombie"
		},
		"disabledog": {
			"translation": "j_utility::disableDog",
			"fullAPI": "disabledog",
			"summary": "Prevent dog rounds from happening.",
			"example": "disabledog"
		},
		"setsupersprinter": {
			"translation": "j_utility::setSuperSprinter",
			"fullAPI": "setsupersprinter([ais], [justspawned])",
			"summary": "Set zombie sprint speed override to super sprinter.",
			"example": "setsupersprinter(zombies, false)",
			"optional1": "[ais] array of zombies to affect.",
			"optional2": "[justspawned] if true, apply only to just spawned zombies."
		},
		"setwalker": {
			"translation": "j_utility::setWalker",
			"fullAPI": "setwalker([ais], [justspawned])",
			"summary": "Set zombie speed override to walker.",
			"example": "setwalker(zombies, false)",
			"optional1": "[ais] array of zombies to affect.",
			"optional2": "[justspawned] if true, apply only to just spawned zombies."
		}
	},
	"ai": {
		"spawnai": {
			"translation": "j_utility::spawnAi",
			"fullAPI": "spawnai(<position>, [ally], [failsafe], [disable_search], [invulnerable], [targetname], [actor])",
			"summary": "Spawn an AI/NPC at a position with various options.",
			"example": "ai = spawnai(struct.origin, true, true)",
			"mandatory1": "<position> The spawn position as vector.",
			"optional1": "[ally] if true, AI is friendly.",
			"optional2": "[failsafe] if true, enable failsafe teleport.",
			"optional3": "[disable_search] if true, AI won't search for targets.",
			"optional4": "[invulnerable] if true, AI can't be damaged.",
			"optional5": "[targetname] custom targetname for the AI.",
			"optional6": "[actor] specific actor archetype to spawn."
		},
		"aisetgoal": {
			"translation": "j_ai::aiSetGoal",
			"fullAPI": "aisetgoal(<goal>)",
			"summary": "Set the AI destination to move to.",
			"example": "ai thr aisetgoal(destination.origin)",
			"mandatory1": "<goal> The destination origin or entity."
		},
		"aistartfollow": {
			"translation": "j_ai::aiStartFollow",
			"fullAPI": "aistartfollow(<player>, [speedup])",
			"summary": "Make the AI follow a player.",
			"example": "ai thr aistartfollow(player, true)",
			"mandatory1": "<player> The player to follow.",
			"optional1": "[speedup] if true, AI speeds up to catch up."
		},
		"aistopfollow": {
			"translation": "j_ai::aiStopFollow",
			"fullAPI": "aistopfollow()",
			"summary": "Stop the AI from following.",
			"example": "ai thr aistopfollow"
		},
		"aisetfake": {
			"translation": "j_ai::aiSetFake",
			"fullAPI": "aisetfake(<model>, [speed], [offset], [pushable])",
			"summary": "Replace the AI visual with a custom model while keeping AI logic.",
			"example": "ai thr aisetfake('my_model', 1.0, (0,0,0), true)",
			"mandatory1": "<model> The visual model name.",
			"optional1": "[speed] movement speed multiplier.",
			"optional2": "[offset] position offset vector.",
			"optional3": "[pushable] if true, players can push the fake model."
		},
		"aisetfakeanim": {
			"translation": "j_ai::aiSetFakeAnim",
			"fullAPI": "aisetfakeanim(<walk>, <idle>, <attack>, <death>)",
			"summary": "Set custom animations for a fake AI model.",
			"example": "ai thr aisetfakeanim('walk_anim', 'idle_anim', 'attack_anim', 'death_anim')",
			"mandatory1": "<walk> walk animation name.",
			"mandatory2": "<idle> idle animation name.",
			"mandatory3": "<attack> attack animation name.",
			"mandatory4": "<death> death animation name."
		}
	},
	"area-queries": {
		"getnearestzombie": {
			"translation": "j_utility::getNearestZombie",
			"fullAPI": "getnearestzombie(<point>, [distance])",
			"summary": "Get the single closest zombie to a point.",
			"example": "zom = getnearestzombie(self.origin, 1000)",
			"mandatory1": "<point> The origin point to search from.",
			"optional1": "[distance] max search distance."
		},
		"getzombiearound": {
			"translation": "j_utility::getZombieAround",
			"fullAPI": "getzombiearound(<origin>, [distance], [excluders], [mindist])",
			"summary": "Get an array of zombies sorted by distance from a point.",
			"example": "zombies = getzombiearound(self.origin, 500)",
			"mandatory1": "<origin> The origin point to search from.",
			"optional1": "[distance] max search distance.",
			"optional2": "[excluders] array of zombies to exclude.",
			"optional3": "[mindist] minimum distance."
		},
		"getplayersaround": {
			"translation": "j_utility::getPlayersAround",
			"fullAPI": "getplayersaround(<origin>, [distance], [excluders], [mindist])",
			"summary": "Get an array of players sorted by distance from a point.",
			"example": "nearby = getplayersaround(self.origin, 300)",
			"mandatory1": "<origin> The origin point to search from.",
			"optional1": "[distance] max search distance.",
			"optional2": "[excluders] array of players to exclude.",
			"optional3": "[mindist] minimum distance."
		},
		"getentaround": {
			"translation": "j_utility::getEntAround",
			"fullAPI": "getentaround(<name>, <origin>, [distance], [excluders], [mindist])",
			"summary": "Get entities by targetname sorted by distance.",
			"example": "ents = getentaround('barricade', self.origin, 500)",
			"mandatory1": "<name> The targetname to search for.",
			"mandatory2": "<origin> The origin point to search from.",
			"optional1": "[distance] max search distance.",
			"optional2": "[excluders] array of entities to exclude.",
			"optional3": "[mindist] minimum distance."
		},
		"getstructaround": {
			"translation": "j_utility::getStructAround",
			"fullAPI": "getstructaround(<name>, <origin>, [distance], [excluders], [mindist], [type])",
			"summary": "Get structs by targetname sorted by distance.",
			"example": "structs = getstructaround('spawn_point', self.origin, 1000)",
			"mandatory1": "<name> The targetname to search for.",
			"mandatory2": "<origin> The origin point to search from.",
			"optional1": "[distance] max search distance.",
			"optional2": "[excluders] array of structs to exclude.",
			"optional3": "[mindist] minimum distance.",
			"optional4": "[type] struct type filter."
		},
		"getzombiesinarea": {
			"translation": "j_utility::getZombiesInArea",
			"fullAPI": "getzombiesinarea(<zone>, [zone2])",
			"summary": "Get zombies touching a trigger zone.",
			"example": "zoms = getzombiesinarea(trigger)",
			"mandatory1": "<zone> The trigger to check.",
			"optional1": "[zone2] optional second trigger to also check."
		},
		"getplayersinarea": {
			"translation": "j_utility::getPlayersInArea",
			"fullAPI": "getplayersinarea(<zone>)",
			"summary": "Get players touching a trigger zone.",
			"example": "players = getplayersinarea(trigger)",
			"mandatory1": "<zone> The trigger to check."
		},
		"isplayerinarea": {
			"translation": "j_utility::isPlayerInArea",
			"fullAPI": "isplayerinarea(<zone>)",
			"summary": "Check if self (player) is inside a trigger zone.",
			"example": "if self isplayerinarea(trigger)",
			"mandatory1": "<zone> The trigger to check."
		}
	},
	"hud": {
		"createtexthud": {
			"translation": "j_utility::createTextHuD",
